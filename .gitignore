# --- Compiled binaries ---
# The runtime CLI built to repo root, and the build tool if compiled locally.
/maple
/build
/maple-colorscripts
*.exe
*.dll
*.so
*.dylib

# --- Go test & build artifacts ---
*.test
*.out
coverage.out
coverage.html
*.prof

# --- Go workspace files (machine-local) ---
go.work
go.work.sum

# --- Vendored deps (modules don't need this; ignore if ever created) ---
/vendor/

# --- Distribution output ---
/dist/
*.tmp

# --- Editor / OS cruft ---
.DS_Store
.idea/
.vscode/
*.swp
*~

# --- Internal design docs (kept local / unpublished) ---
docs/superpowers/

# NOTE: colorscripts/ and maple.json are build-generated but ARE committed
